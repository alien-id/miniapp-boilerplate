# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/miniapp

# Set to "true" to run migrations automatically on server start
# RUN_MIGRATIONS=true

# Auth: JWKS URL for JWT token verification (differs between dev/prod)
ALIEN_JWKS_URL=https://sso.alien-api.com/oauth/jwks

# Payments: Ed25519 public key (hex) for webhook signature verification
WEBHOOK_PUBLIC_KEY=

# Payments: Solana wallet address that receives USDC/SOL payments (exposed to the browser)
NEXT_PUBLIC_RECIPIENT_ADDRESS=

# Payments: Alien chain address that receives ALIEN token payments (exposed to the browser)
NEXT_PUBLIC_ALIEN_RECIPIENT_ADDRESS=

# Node environment
NODE_ENV=development

# Cosign: Avatar upload (Vercel Blob). Get token at: Vercel Dashboard → Storage → Blob → Create store → copy BLOB_READ_WRITE_TOKEN
# Without this, avatar upload returns 503.
BLOB_READ_WRITE_TOKEN=

# Cosign: LinkedIn auto-fill (Apify). Get token at: https://console.apify.com/settings/integrations — use code ALIEN_ESI_APIFYHACKER for credits
# Without this, "Auto-fill from LinkedIn" returns 503.
APIFY_API_TOKEN=

# Cosign: Base URL for review links (e.g. https://your-app.vercel.app). Falls back to VERCEL_URL or http://localhost:3000 if unset.
NEXT_PUBLIC_APP_URL=
